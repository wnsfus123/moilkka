# 카카오 OAuth
REACT_APP_KAKAO_REST_API_KEY=
REACT_APP_KAKAO_REDIRECT_URI=

# 배포 URL (로컬: http://localhost:3000, 프로덕션: https://your-domain.vercel.app)
REACT_APP_BASE_URL=

# 구글 캘린더
REACT_APP_GOOGLE_CLIENT_ID=
REACT_APP_GOOGLE_API_KEY=

# Supabase (클라이언트용 - 공개)
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_ANON_KEY=

# Supabase (서버 API용 - 비공개)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# 토큰 암호화 키 (32바이트 = 64자리 hex 또는 32자 문자열)
ENCRYPTION_SECRET_KEY=

# Vercel Cron 인증
CRON_SECRET=
